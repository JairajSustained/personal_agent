# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google
GOOGLE_API_KEY=

# Azure Foundry (OpenAI-compatible endpoint)
# Example endpoint: https://<resource>.services.ai.azure.com/models
AZURE_FOUNDRY_API_KEY=
# Optional fallback key name supported by some Azure setups
AZURE_OPENAI_API_KEY=
AZURE_FOUNDRY_ENDPOINT=

# Common Azure aliases
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_API_VERSION=2025-01-01-preview

# Optional: path to a LibreChat-style config file
LIBRECHAT_CONFIG_PATH=

# Optional: persistent memory file path (defaults to ~/.personal_agent/memory.txt)
MEMORY_FILE_PATH=
